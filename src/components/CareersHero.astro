---
// src/components/CareersHero.astro
// Careers hero section — CAREER-01
// Gradient hero targeting prospective agents/VAs — no Calendly dependency
import { careersHero } from '../data/careersContent.ts';
---

<section class="relative overflow-hidden bg-gradient-to-br from-teal via-blue to-navy py-24 md:py-32">
  <!-- W-arrow brand watermark -->
  <div class="absolute top-1/2 right-0 -translate-y-1/2 translate-x-1/4 opacity-10 pointer-events-none" aria-hidden="true">
    <svg class="w-[500px] h-[500px] text-white" viewBox="0 0 556.27 519.13" fill="currentColor" aria-hidden="true">
      <path d="M458.7,158.04c-1.3-6.04-2.59-12.08-3.88-18.12-.69-3.22-1.38-6.43-2.06-9.64-.16-.74-.3-1.5-.52-2.22-.01.07-.3-.49-.53-.9-.13-.14-.26-.28-.33-.3-.05-.04-.09-.07-.13-.11-.24-.15-.49-.29-.75-.43-.19-.05-.38-.11-.56-.16-.05,0-.09-.02-.13-.03-.12,0-.34,0-.67-.02-.25.04-.69.04-1.01.07-.38.03-.76.09-1.14.14-.17.02-.34.04-.51.06-1.01.12-2.03.24-3.05.37-.91.11-1.83.22-2.75.34l-96.22,286.84-82.86-241.6h-24.66l-82.85,241.6-80.32-241.6h-36.69l97.4,290.92h34.78l79.69-230.84,79.06,230.84h34.78l101.27-299.34c-2.57-1.01-4.8-3.28-5.36-5.86"/>
      <path d="M485.55,44.22l-160.25,88.43c.98-.35,2.03-.62,3.17-.71l118.53-14.37,1.33-.16c5.95-.5,11.34,3.5,12.59,9.34l6.21,28.98,33.5-97.31c3.18-9.25-6.04-17.93-15.08-14.19"/>
    </svg>
  </div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- "Now Hiring" badge pill -->
    <span class="inline-block bg-yellow/20 text-yellow font-heading font-semibold text-sm px-4 py-1.5 rounded-full mb-6 tracking-wide uppercase">
      {careersHero.badge}
    </span>

    <h1 class="text-3xl md:text-4xl lg:text-5xl font-heading font-bold text-white leading-tight">
      {careersHero.headline}
    </h1>
    <p class="mt-6 text-white/80 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
      {careersHero.subtitle}
    </p>

    <div class="mt-10">
      <a
        href="#apply"
        class="inline-block bg-yellow text-navy font-heading font-bold px-7 py-3.5 rounded-full hover:bg-yellow/90 transition-colors"
      >
        Apply Now
      </a>
    </div>
  </div>
</section>
