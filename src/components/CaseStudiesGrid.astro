---
// src/components/CaseStudiesGrid.astro
// 2-column responsive grid of case study cards — driven by caseStudies.ts data file.
// Adding a new object to caseStudies.ts automatically renders a new card here.
import { caseStudies } from '../data/caseStudies';
---
<section class="bg-white py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-2 gap-8">
      {caseStudies.map((study) => (
        <article class="flex flex-col p-6 lg:p-8 rounded-2xl bg-gray-50 hover:shadow-md transition-shadow">

          <!-- Industry pill + role type + icon -->
          <div class="flex items-center gap-3 mb-4 flex-wrap">
            <!-- Industry icon -->
            <div class="flex-shrink-0 w-9 h-9 rounded-full bg-teal/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-teal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={study.iconPath} />
              </svg>
            </div>
            <!-- Industry pill -->
            <span class="inline-block bg-teal/10 text-teal text-xs font-semibold uppercase tracking-wide px-3 py-1 rounded-full">
              {study.industry}
            </span>
            <!-- Role type -->
            <span class="text-gray-500 text-xs">{study.roleType}</span>
          </div>

          <!-- Company name -->
          <h3 class="text-xl font-heading font-bold text-navy mb-1">
            {study.companyName}
          </h3>

          <!-- Outcome stat — visually prominent (CASE-02) -->
          <p class="text-3xl font-heading font-bold text-teal my-3">
            {study.outcomeStat}
          </p>

          <!-- Challenge -->
          <p class="text-gray-600 text-sm leading-relaxed mb-3">
            <span class="font-semibold text-navy">Challenge:</span> {study.challenge}
          </p>

          <!-- Outcome / Result -->
          <p class="text-gray-600 text-sm leading-relaxed">
            <span class="font-semibold text-navy">Result:</span> {study.outcome}
          </p>

        </article>
      ))}
    </div>
  </div>
</section>
