---
// src/components/CoreValues.astro
// Core values section — ABOUT-05
// Teal gradient background with W-arrow watermark, values grid around center photo
import { coreValues } from '../data/aboutContent';
---
<section class="relative overflow-hidden bg-gradient-to-br from-teal via-teal to-blue py-16 md:py-24">
  <!-- W-arrow brand watermark -->
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 opacity-10 pointer-events-none" aria-hidden="true">
    <svg class="w-[600px] h-[600px] text-white" viewBox="0 0 556.27 519.13" fill="currentColor" aria-hidden="true">
      <path d="M458.7,158.04c-1.3-6.04-2.59-12.08-3.88-18.12-.69-3.22-1.38-6.43-2.06-9.64-.16-.74-.3-1.5-.52-2.22-.01.07-.3-.49-.53-.9-.13-.14-.26-.28-.33-.3-.05-.04-.09-.07-.13-.11-.24-.15-.49-.29-.75-.43-.19-.05-.38-.11-.56-.16-.05,0-.09-.02-.13-.03-.12,0-.34,0-.67-.02-.25.04-.69.04-1.01.07-.38.03-.76.09-1.14.14-.17.02-.34.04-.51.06-1.01.12-2.03.24-3.05.37-.91.11-1.83.22-2.75.34l-96.22,286.84-82.86-241.6h-24.66l-82.85,241.6-80.32-241.6h-36.69l97.4,290.92h34.78l79.69-230.84,79.06,230.84h34.78l101.27-299.34c-2.57-1.01-4.8-3.28-5.36-5.86"/>
      <path d="M485.55,44.22l-160.25,88.43c.98-.35,2.03-.62,3.17-.71l118.53-14.37,1.33-.16c5.95-.5,11.34,3.5,12.59,9.34l6.21,28.98,33.5-97.31c3.18-9.25-6.04-17.93-15.08-14.19"/>
    </svg>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl md:text-4xl font-heading font-bold text-white text-center mb-12">
      Our Core Values
    </h2>

    <!-- Desktop: 3-column grid with center photo — Mobile: stacked list -->
    <div class="hidden md:grid md:grid-cols-3 gap-6 items-center">

      <!-- Left column: first 3 values -->
      <div class="space-y-6">
        {coreValues.slice(0, 3).map((value) => (
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-14 h-14 rounded-full bg-navy flex items-center justify-center">
              <svg class="w-6 h-6 text-teal-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={value.iconPath} />
              </svg>
            </div>
            <div>
              <h3 class="font-heading font-bold text-white text-lg mb-1">{value.title}</h3>
              <p class="text-white/80 text-sm leading-relaxed">{value.description}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Center column: photo -->
      <div class="flex justify-center">
        <div class="relative">
          <img
            src="/images/about-values.jpg"
            alt="WorkWiser team members collaborating"
            class="w-72 h-80 object-cover rounded-2xl shadow-2xl"
            width="288"
            height="320"
            onerror="this.style.opacity='0'"
          />
        </div>
      </div>

      <!-- Right column: remaining values -->
      <div class="space-y-6">
        {coreValues.slice(3).map((value) => (
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-14 h-14 rounded-full bg-navy flex items-center justify-center">
              <svg class="w-6 h-6 text-teal-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={value.iconPath} />
              </svg>
            </div>
            <div>
              <h3 class="font-heading font-bold text-white text-lg mb-1">{value.title}</h3>
              <p class="text-white/80 text-sm leading-relaxed">{value.description}</p>
            </div>
          </div>
        ))}
      </div>

    </div>

    <!-- Mobile: stacked list with photo in middle -->
    <div class="md:hidden space-y-6">
      {coreValues.slice(0, 3).map((value) => (
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-14 h-14 rounded-full bg-navy flex items-center justify-center">
            <svg class="w-6 h-6 text-teal-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d={value.iconPath} />
            </svg>
          </div>
          <div>
            <h3 class="font-heading font-bold text-white text-lg mb-1">{value.title}</h3>
            <p class="text-white/80 text-sm leading-relaxed">{value.description}</p>
          </div>
        </div>
      ))}

      <!-- Photo between value groups on mobile -->
      <div class="flex justify-center py-4">
        <img
          src="/images/about-values.jpg"
          alt="WorkWiser team members collaborating"
          class="w-full max-w-sm h-64 object-cover rounded-2xl shadow-2xl"
          width="400"
          height="256"
          onerror="this.style.opacity='0'"
        />
      </div>

      {coreValues.slice(3).map((value) => (
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-14 h-14 rounded-full bg-navy flex items-center justify-center">
            <svg class="w-6 h-6 text-teal-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d={value.iconPath} />
            </svg>
          </div>
          <div>
            <h3 class="font-heading font-bold text-white text-lg mb-1">{value.title}</h3>
            <p class="text-white/80 text-sm leading-relaxed">{value.description}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
