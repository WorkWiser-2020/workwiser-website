---
// src/components/Hero.astro
// Hero section — HOME-01, HOME-07
// Split layout: blue gradient left, photo right (matching Canva mockup)
---
<section class="relative min-h-[580px] lg:min-h-[680px] overflow-hidden bg-gradient-to-br from-blue via-blue to-navy">
  <!-- Photo positioned on the right side -->
  <div class="absolute inset-0">
    <img
      src="/images/hero.jpg"
      alt="WorkWiser virtual assistant professional"
      class="absolute right-0 top-0 h-full w-full lg:w-3/5 object-cover object-top"
      width="1920"
      height="1080"
    />
    <!-- Gradient overlay to blend photo into the blue background on the left -->
    <div class="absolute inset-0 bg-gradient-to-r from-blue via-blue/90 to-transparent"></div>
  </div>

  <!-- W-arrow brand element as subtle background watermark -->
  <div class="absolute bottom-0 right-1/4 opacity-10 pointer-events-none">
    <svg class="w-[400px] h-[400px] text-white" viewBox="0 0 556.27 519.13" fill="currentColor" aria-hidden="true">
      <path d="M458.7,158.04c-1.3-6.04-2.59-12.08-3.88-18.12-.69-3.22-1.38-6.43-2.06-9.64-.16-.74-.3-1.5-.52-2.22-.01.07-.3-.49-.53-.9-.13-.14-.26-.28-.33-.3-.05-.04-.09-.07-.13-.11-.24-.15-.49-.29-.75-.43-.19-.05-.38-.11-.56-.16-.05,0-.09-.02-.13-.03-.12,0-.34,0-.67-.02-.25.04-.69.04-1.01.07-.38.03-.76.09-1.14.14-.17.02-.34.04-.51.06-1.01.12-2.03.24-3.05.37-.91.11-1.83.22-2.75.34l-96.22,286.84-82.86-241.6h-24.66l-82.85,241.6-80.32-241.6h-36.69l97.4,290.92h34.78l79.69-230.84,79.06,230.84h34.78l101.27-299.34c-2.57-1.01-4.8-3.28-5.36-5.86"/>
      <path d="M485.55,44.22l-160.25,88.43c.98-.35,2.03-.62,3.17-.71l118.53-14.37,1.33-.16c5.95-.5,11.34,3.5,12.59,9.34l6.21,28.98,33.5-97.31c3.18-9.25-6.04-17.93-15.08-14.19"/>
    </svg>
  </div>

  <!-- Content on the left -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 flex items-center min-h-[580px] lg:min-h-[680px]">
    <div class="max-w-xl">
      <p class="text-yellow font-heading font-bold text-sm uppercase tracking-widest mb-4">
        More than a Virtual Assistant agency
      </p>

      <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold leading-tight">
        <span class="text-white">We are your</span><br />
        <span class="text-yellow">Trusted Partners</span>
      </h1>

      <p class="mt-6 text-lg text-white/90 leading-relaxed">
        Empower your business with top-tier Latin American talent—hire, onboard, and manage virtual professionals effortlessly.
      </p>

      <div class="mt-8">
        <a
          href="https://calendly.com/workwiser-info/ceo-client"
          class="inline-block bg-yellow text-navy font-heading font-bold px-7 py-3.5 rounded-full hover:bg-yellow/90 transition-colors"
          target="_blank"
          rel="noopener"
        >
          Start delegating
        </a>
      </div>
    </div>
  </div>
</section>
