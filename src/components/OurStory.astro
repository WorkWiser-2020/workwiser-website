---
// src/components/OurStory.astro
// Our Story section
// Light background, gradient text heading, three paragraphs
import { ourStory } from '../data/aboutContent';
---
<section class="bg-white py-16 md:py-24">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl md:text-4xl font-heading font-bold mb-10 bg-gradient-to-r from-teal to-navy bg-clip-text text-transparent inline-block">
      {ourStory.heading}
    </h2>
    <div class="space-y-6 text-left">
      {ourStory.paragraphs.map((paragraph) => (
        <p class="text-navy/80 leading-relaxed text-lg">{paragraph}</p>
      ))}
    </div>
  </div>
</section>
