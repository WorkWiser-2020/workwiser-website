---
// src/components/ProcessSteps.astro
// 5-step process section — HOME-05
// "one-stop solution" heading with 2-column numbered list, yellow circles (matching Canva mockup)
import { processSteps } from '../data/homeContent.ts';

const leftSteps = processSteps.filter(s => s.step <= 3);
const rightSteps = processSteps.filter(s => s.step >= 4);
---
<section class="bg-white py-16 lg:py-24 relative overflow-hidden">
  <!-- Subtle dot grid texture -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, #003c64 1px, transparent 1px); background-size: 24px 24px;"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section heading -->
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-heading font-bold text-navy">
        WorkWiser is a <span class="text-yellow" style="text-decoration: underline; text-decoration-color: #f3f145; text-underline-offset: 6px;">one-stop</span> solution
      </h2>
    </div>

    <!-- 2-column layout: steps 1-3 left, steps 4-5 right -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-16 gap-y-8 max-w-4xl mx-auto">
      <!-- Left column: steps 1-3 -->
      <div class="space-y-8">
        {leftSteps.map(step => (
          <div class="flex gap-4">
            <div class="w-10 h-10 rounded-full bg-yellow text-navy font-heading font-bold flex items-center justify-center text-lg flex-shrink-0">
              {step.step}
            </div>
            <div>
              <h3 class="font-heading font-bold text-navy text-lg">
                {step.title}
              </h3>
              <p class="mt-1 text-navy/60 text-sm leading-relaxed">
                {step.description}
              </p>
            </div>
          </div>
        ))}
      </div>

      <!-- Right column: steps 4-5 -->
      <div class="space-y-8">
        {rightSteps.map(step => (
          <div class="flex gap-4">
            <div class="w-10 h-10 rounded-full bg-yellow text-navy font-heading font-bold flex items-center justify-center text-lg flex-shrink-0">
              {step.step}
            </div>
            <div>
              <h3 class="font-heading font-bold text-navy text-lg">
                {step.title}
              </h3>
              <p class="mt-1 text-navy/60 text-sm leading-relaxed">
                {step.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
