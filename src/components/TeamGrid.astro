---
// src/components/TeamGrid.astro
// Team placeholder grid — ABOUT-06
// 2-col mobile, 4-col desktop, local photo files
import { teamMembers } from '../data/aboutContent';
---
<section class="bg-gray-50 py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl md:text-4xl font-heading font-bold text-navy text-center mb-12">
      Meet Our Team
    </h2>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {teamMembers.map((member) => (
        <div class="text-center">
          <img
            src={member.imageUrl}
            alt={`${member.name}, ${member.title}`}
            class="w-full aspect-square object-cover rounded-xl mb-4"
            width="300"
            height="300"
            onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22300%22 height=%22300%22 viewBox=%220 0 300 300%22%3E%3Crect width=%22300%22 height=%22300%22 fill=%22%23effefe%22/%3E%3Ccircle cx=%22150%22 cy=%22110%22 r=%2250%22 fill=%22%2326aeb4%22/%3E%3Cellipse cx=%22150%22 cy=%22230%22 rx=%2280%22 ry=%2260%22 fill=%22%2226aeb4%22/%3E%3C/svg%3E'"
          />
          <h3 class="font-heading font-bold text-navy text-base">{member.name}</h3>
          <p class="text-navy/60 text-sm mt-1">{member.title}</p>
        </div>
      ))}
    </div>

    <p class="text-center text-navy/50 text-sm mt-10 italic">
      Team photos will be updated before launch.
    </p>
  </div>
</section>
