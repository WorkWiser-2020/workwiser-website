---
// src/components/Testimonials.astro
// Testimonials section — HOME-06
// Heading left, photo cards right (matching Canva mockup)
import { testimonials } from '../data/homeContent.ts';
---
<section class="bg-teal-light py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-12 items-start">
      <!-- Left: heading -->
      <div>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-navy leading-tight">
          Real Results Delivered By WorkWiser VA's
        </h2>
        <p class="mt-3 text-navy/60 text-sm">
          Hear How Our Assistants Help Businesses Thrive
        </p>
      </div>

      <!-- Right: testimonial cards with photos -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {testimonials.map(testimonial => (
          <figure class="flex flex-col">
            <!-- Photo -->
            <div class="aspect-[4/3] rounded-xl overflow-hidden mb-4 bg-navy/10">
              <img
                src={testimonial.image}
                alt={testimonial.name}
                class="w-full h-full object-cover"
                width="320"
                height="240"
                onerror="this.style.display='none'"
              />
            </div>

            <!-- Quote -->
            <blockquote class="text-navy/70 text-sm leading-relaxed flex-1">
              {testimonial.quote}
            </blockquote>

            <!-- Attribution -->
            <figcaption class="mt-4">
              <p class="font-heading font-bold text-navy text-sm">{testimonial.name}</p>
              <p class="text-navy/50 text-xs">{testimonial.title}</p>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </div>
</section>
