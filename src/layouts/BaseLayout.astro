---
import { Font } from 'astro:assets';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'WorkWiser — Your Trusted Virtual Assistant Partners',
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | WorkWiser`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL('/images/hero.jpg', Astro.site ?? Astro.url).href} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:type" content="website" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | WorkWiser`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/images/hero.jpg', Astro.site ?? Astro.url).href} />
    <!-- Canonical -->
    <link rel="canonical" href={Astro.url.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | WorkWiser</title>
    <Font cssVariable="--font-open-sauce-one" preload />
    <Font cssVariable="--font-inter" preload />
    <slot name="head" />
  </head>
  <body class="font-body text-navy">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
