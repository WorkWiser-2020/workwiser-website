---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactHero from '../components/ContactHero.astro';
import ContactForm from '../components/ContactForm.astro';
import ContactSidebar from '../components/ContactSidebar.astro';
---
<BaseLayout
  title="Contact Us - WorkWiser"
  description="Contact WorkWiser to hire skilled virtual assistants for your business. Submit an inquiry, book a free consultation call, or reach us directly at info@workwiser.io."
>
  <Fragment slot="head">
    <link href="https://calendly.com/assets/external/widget.css" rel="stylesheet" />
    <script is:inline src="https://calendly.com/assets/external/widget.js" type="text/javascript"></script>
  </Fragment>

  <ContactHero />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-16">
      <!-- Left column: Contact Form (2/3 width) -->
      <div class="lg:col-span-2">
        <ContactForm />
      </div>
      <!-- Right column: Sidebar (1/3 width) -->
      <div class="lg:col-span-1">
        <ContactSidebar />
      </div>
    </div>
  </div>
</BaseLayout>
